# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env

# URL koneksi PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/imhungry

# Secret key untuk signing JWT — ganti dengan string acak yang panjang di production
# Generate contoh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret

# Durasi token JWT dalam menit (default 1440 = 24 jam)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# YouTube Data API v3 (untuk pencarian video resep)
YOUTUBE_API=your-youtube-data-api-key

# Google Gemini API (untuk AI chat & generate resep)
GOOGLE_API_KEY=your-gemini-api-key


